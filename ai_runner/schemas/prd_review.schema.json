{
  "type": "object",
  "additionalProperties": false,
  "required": ["conclusion", "summary", "findings", "required_changes", "suggested_dev_notes"],
  "properties": {
    "conclusion": {
      "type": "string",
      "enum": ["APPROVED", "REJECTED", "NEED_CLARIFICATION", "SPLIT_REQUIRED"]
    },
    "summary": { "type": "string" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "area", "message", "evidence"],
        "properties": {
          "severity": { "type": "string" },
          "area": { "type": "string" },
          "message": { "type": "string" },
          "evidence": { "type": "string" }
        }
      }
    },
    "required_changes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "suggested_dev_notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}

